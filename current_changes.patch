+                        "player_uuid CHAR(36) NOT NULL," +
+                        "variable_key VARCHAR(128) NOT NULL," +
+                        "value MEDIUMTEXT NULL," +
+                        "updated_at BIGINT NOT NULL," +
+                        "first_modified_at BIGINT NOT NULL," +
+                        "op VARCHAR(16) NOT NULL DEFAULT 'OTHER'," +
+                        "scope VARCHAR(16) NOT NULL DEFAULT 'PLAYER'," +
+                        "PRIMARY KEY (id)" +
+                        ")",
+                "CREATE TABLE IF NOT EXISTS player_variable_change_consumers (" +
+                        "server_id VARCHAR(64) NOT NULL," +
+                        "last_event_id BIGINT NOT NULL," +
+                        "updated_at BIGINT NOT NULL," +
+                        "PRIMARY KEY (server_id)" +
+                        ")"
+        );
+        for (String sql : ddl) {
+            try (PreparedStatement stmt = connection.prepareStatement(sql)) {
+                stmt.executeUpdate();
+            }
+        }
+
+        // 兼容旧库：确保新增列存在
+        ensureColumn(connection, "player_variable_change_events", "op",
+                "ALTER TABLE player_variable_change_events ADD COLUMN op VARCHAR(16) NOT NULL DEFAULT 'OTHER'");
+        ensureColumn(connection, "player_variable_change_events", "scope",
+                "ALTER TABLE player_variable_change_events ADD COLUMN scope VARCHAR(16) NOT NULL DEFAULT 'PLAYER'");
+
+        List<String> idx = List.of(
+                "CREATE INDEX idx_pvce_player ON player_variable_change_events(player_uuid)",
+                "CREATE INDEX idx_pvce_key ON player_variable_change_events(variable_key)",
+                "CREATE INDEX idx_pvce_server ON player_variable_change_events(server_id)",
+                "CREATE INDEX idx_pvce_updated ON player_variable_change_events(updated_at)",
+                "CREATE INDEX idx_pvce_scope ON player_variable_change_events(scope)",
+                "CREATE INDEX idx_pvce_created ON player_variable_change_events(created_at)"
+        );
+        for (String sql : idx) {
+            try (PreparedStatement stmt = connection.prepareStatement(sql)) {
+                stmt.executeUpdate();
+            } catch (SQLException e) {
+                if (e.getErrorCode() == 1061 || (e.getMessage() != null && e.getMessage().toLowerCase().contains("duplicate key name"))) {
+                    continue;
+                }
+                throw e;
+            }
+        }
+        logger.debug("跨服同步表结构初始化完成");
+    }
+
+    private void ensureColumn(Connection connection, String table, String column, String alterSql) throws SQLException {
+        String sql = "SELECT COUNT(*) FROM information_schema.COLUMNS WHERE TABLE_SCHEMA = DATABASE() AND TABLE_NAME = ? AND COLUMN_NAME = ?";
+        try (PreparedStatement stmt = connection.prepareStatement(sql)) {
+            stmt.setString(1, table);
+            stmt.setString(2, column);
+            try (ResultSet rs = stmt.executeQuery()) {
+                if (rs.next() && rs.getInt(1) > 0) {
+                    return;
+                }
+            }
+        }
+        try (PreparedStatement stmt = connection.prepareStatement(alterSql)) {
+            stmt.executeUpdate();
+        } catch (SQLException e) {
+            if (e.getErrorCode() == 1060 || (e.getMessage() != null && e.getMessage().toLowerCase().contains("duplicate column name"))) {
+                return;
+            }
+            throw e;
+        }
+    }
