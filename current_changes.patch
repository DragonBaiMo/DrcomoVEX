+
+        static VarQueryMode from(String raw) {
+            if (raw == null) return null;
+            String v = raw.trim().toLowerCase();
+            return switch (v) {
+                case "max" -> MAX;
+                case "min" -> MIN;
+                case "initial" -> INITIAL;
+                default -> null;
+            };
+        }
+    }
