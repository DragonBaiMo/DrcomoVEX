+    private String resolveVarMetaValue(OfflinePlayer player, String key, VarQueryMode mode) {
+        if (!hasVariable(key)) return "变量不存在";
+        Variable var = variablesManager.getVariableDefinition(key);
+        if (var == null) return "变量不存在";
+        if (var.isPlayerScoped() && player == null) {
+            logger.info("占位符 drcomovex_[var] 玩家变量 " + key + " 需要玩家参数");
+            return "需要玩家参数";
+        }
+        boolean allowPapi = Bukkit.isPrimaryThread();
+        return switch (mode) {
+            case MAX -> variablesManager.resolveEffectiveMax(player, key, allowPapi);
+            case MIN -> variablesManager.resolveEffectiveMin(player, key, allowPapi);
