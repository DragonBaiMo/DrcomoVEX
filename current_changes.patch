+    private VarKeyMode resolveVarKeyMode(String rawArgs) {
+        String cleaned = rawArgs.replace(" ", "").trim();
+        Matcher bracket = VAR_SUFFIX_BRACKET_PATTERN.matcher(cleaned);
+        if (bracket.matches()) {
+            String key = normalizeKey(bracket.group(1));
+            VarQueryMode mode = VarQueryMode.from(bracket.group(2));
+            return new VarKeyMode(key, mode != null ? mode : VarQueryMode.VALUE);
+        }
+
+        String normalized = normalizeKey(cleaned);
+        if (variablesManager.getVariableDefinition(normalized) != null) {
+            return new VarKeyMode(normalized, VarQueryMode.VALUE);
+        }
+
+        Matcher plain = VAR_SUFFIX_PLAIN_PATTERN.matcher(cleaned);
+        if (plain.matches()) {
+            String possibleKey = normalizeKey(plain.group(1));
+            String possibleMode = plain.group(2);
+            if (variablesManager.getVariableDefinition(possibleKey) != null) {
+                VarQueryMode mode = VarQueryMode.from(possibleMode);
+                if (mode != null) {
+                    return new VarKeyMode(possibleKey, mode);
+                }
+            }
+        }
+
+        return new VarKeyMode(normalized, VarQueryMode.VALUE);
+    }
+
+    private String normalizeKey(String input) {
+        return input.replace("[", "").replace("]", "").trim();
+    }
+
+    private enum VarQueryMode {
